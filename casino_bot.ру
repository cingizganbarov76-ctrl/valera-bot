@dp.callback_query(F.data.startswith("mine_"))
async def mines_click(call: CallbackQuery):
    uid = call.from_user.id
    game = users[uid].get("mines_game")
    if not game:
        await call.answer("Игра не найдена. Начни заново.", show_alert=True)
        return
    index = int(call.data.split("_")[1])
    if index in game["opened"]:
        await call.answer("Уже открыта!")
        return
    game["opened"].add(index)
    cell = game["board"][index]
    if cell == "💣":
        await call.message.edit_text(
            f"💥 БАБАХ! Ты попал на мину!\nПотеряно: {game['bet']} Valera coins.\n\n"
            f"😢 Не повезло. Подпишись на {YOUR_CHANNEL} — там делятся стратегиями!",
            reply_markup=main_menu()
        )
        del users[uid]["mines_game"]
        await call.answer("Мина!")
        return
    game["multiplier"] += 0.7
    potential = int(game["bet"] * game["multiplier"])
    await call.message.edit_text(
        f"💎 Алмаз! Множитель: x{game['multiplier']:.1f}\nПотенциальный выигрыш: {potential} Valera coins.",
        reply_markup=mines_keyboard(game)
    )
    await call.answer()

