        parse_mode="HTML"
    )
    await call.answer()

@dp.message(F.text.regexp(r'^\d+(\s+\d+)+$'))
async def roulette_play(message: types.Message):
    uid = message.from_user.id
    if uid not in users:
        users[uid] = {"balance": 0, "last_daily": None}
    parts = message.text.split()
    total_bet = int(parts[0])
    numbers = [int(n) for n in parts[1:] if 0 <= int(n) <= 36]
    if not numbers:
        await message.answer("Укажи числа от 0 до 36.")
        return
    if total_bet > users[uid]["balance"]:
        await message.answer("❌ Недостаточно Valera coins!")
        return
    bet_per_number = total_bet // len(numbers)
    if bet_per_number < 1:
        await message.answer("Слишком маленькая ставка на число.")
        return
    users[uid]["balance"] -= bet_per_number * len(numbers)
    result = random.randint(0, 36)
    win_amount = 0
    if result in numbers:
        win_amount = bet_per_number * 36
        users[uid]["balance"] += win_amount
    await message.answer(
        f"🎰 Ставка: {bet_per_number} VC x {len(numbers)} чисел\n"
        f"Твои числа: {', '.join(map(str, numbers))}\n"
        f"Выпало: {result}\n\n"
        f"{'🎉 ВЫИГРЫШ: ' + str(win_amount) + ' Valera coins!' if win_amount else '😢 Мимо. Крути ещё!'}\n\n"
        f"📢 Подпишись на {YOUR_CHANNEL} — там эксклюзивные бонусы!",
        reply_markup=main_menu()
    )

